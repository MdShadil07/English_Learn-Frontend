# ==============================================================================
# FRONTEND / VERCEL PRODUCTION ENVIRONMENT VARIABLES
# ==============================================================================
# Add these exactly in your Vercel Dashboard: Settings -> Environment Variables
# Do NOT prefix with quotes inside Vercel.

# 1. Supabase (Database/Storage) — Same as your local .env
VITE_SUPABASE_PROJECT_ID=nsqmmieqjnngyzcwseqn
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5zcW1taWVxam5uZ3l6Y3dzZXFuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjExNDY2MzAsImV4cCI6MjA3NjcyMjYzMH0.uHBKuuqC4pIS4fVUWdwk3SJNQ-4ujrNVkuIHa-MwCsg
VITE_SUPABASE_URL=https://nsqmmieqjnngyzcwseqn.supabase.co

# 2. Backend API URL
# Replace this with your actual deployed Backend URL on AWS / Render / Railway
# Make sure to include /api at the end, and no trailing slash.
VITE_API_URL=https://your-backend-api.com/api

# 3. Mediasoup SFU URL
# The public IP or domain of your AWS EC2 running the SFU.
# Must match exactly including the port if you didn't use NGINX/HTTPS.
VITE_SFU_URL=https://releases-rover-cope-hawaiian.trycloudflare.com

# 4. Razorpay (Production Key)
VITE_RAZORPAY_KEY_ID=rzp_live_YOUR_PRODUCTION_KEY

# 5. App Info
VITE_APP_ENV=production
VITE_PUBLIC_URL=https://your-vercel-frontend-domain.vercel.app
